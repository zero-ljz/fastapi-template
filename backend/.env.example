PROJECT_NAME="FastAPI Template"
VERSION="1.0.0"
API_V1_STR=/api/v1
ENVIRONMENT=development # development, testing, production
DEBUG=true

# 生产环境请使用至少 32 字符的随机密钥，例如:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-to-a-random-secret-key-32chars-min
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

BACKEND_CORS_ORIGINS=["http://localhost","http://localhost:3000","http://localhost:8080","http://localhost:5173"]

DB_DRIVER=mysql+mysqldb
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=change-me
DB_NAME=db1

LOG_LEVEL=INFO # DEBUG, INFO, WARNING, ERROR, CRITICAL

FIRST_SUPERUSER=admin
FIRST_SUPERUSER_EMAIL=admin@example.com
FIRST_SUPERUSER_PASSWORD=change-me-admin-password
