{
  "name": "fastapi-template",
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "concurrently --kill-others --names backend,frontend --prefix-colors blue,green \"npm:dev:backend\" \"npm:dev:frontend\"",
    "dev:backend": "node scripts/backend-python.mjs -m uvicorn app.main:app --host 127.0.0.1 --port 8000 --reload",
    "dev:frontend": "npm --prefix frontend run dev",
    "api:generate": "node scripts/backend-python.mjs scripts/export_openapi.py ../frontend/openapi.json && npm --prefix frontend run api:types",
    "test:frontend": "npm --prefix frontend test",
    "build:frontend": "npm --prefix frontend run build"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
